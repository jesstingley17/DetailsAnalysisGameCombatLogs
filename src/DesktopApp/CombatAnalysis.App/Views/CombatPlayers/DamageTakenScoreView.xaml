<views:MvxWpfView x:Class="CombatAnalysis.App.Views.CombatPlayers.DamageTakenScoreView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:CombatAnalysis.App.Converters"
    xmlns:convertersCombat="clr-namespace:CombatAnalysis.App.Converters.CombatLogs"
    xmlns:loc="clr-namespace:CombatAnalysis.App.Localizations"
    xmlns:resx="clr-namespace:CombatAnalysis.App.Localizations.Resources.DamageTakenScore"
    xmlns:local="clr-namespace:CombatAnalysis.App.Views.ViewTemplates"
    xmlns:mvx="clr-namespace:MvvmCross.Platforms.Wpf.Binding;assembly=MvvmCross.Platforms.Wpf"
    xmlns:views="clr-namespace:MvvmCross.Platforms.Wpf.Views;assembly=MvvmCross.Platforms.Wpf"
    loc:LocalizationObject.ResourceManager="{x:Static resx:Resource.ResourceManager}"
    mc:Ignorable="d">
    
    <Grid>
        <Grid.Resources>
            <converters:TheNativeIntToVisibilityConverter x:Key="IntToVisibility" />
            <converters:TheNativeBoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
            <convertersCombat:IntToEnhancedIntConverter x:Key="IntToEnhancedInt" />
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Margin="50 0">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="15" Margin="20 0" VerticalAlignment="Center">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ClearMinValueCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                            <TextBlock Text="{loc:Loc MinDamageTaken}" Margin="0 20" FontSize="14" Foreground="White"/>
                            <Icon:PackIconMaterial Margin="20 0" Foreground="White" Width="15" VerticalAlignment="Center">
                                <Icon:PackIconMaterial.Style>
                                    <Style TargetType="Icon:PackIconMaterial">
                                        <Setter Property="Kind" Value="Pen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinValue}" Value="True">
                                                <Setter Property="Kind" Value="GamepadDown"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Icon:PackIconMaterial.Style>
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinValueCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <StackPanel Cursor="Hand" ToolTip="{loc:Loc EditValue}" HorizontalAlignment="Center">
                            <TextBox Text="{Binding MinValue, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Bold" Foreground="Black" Width="125">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinValue}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding ApplyMinValueCommand}" Gesture="Enter" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="{Binding MinValue}" FontSize="14" FontWeight="Bold" Foreground="White" Width="125">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinValue}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinValueCommand}" Gesture="LeftClick"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="50 0">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="15" Margin="20 0" VerticalAlignment="Center">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ClearMinVPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                            <TextBlock Text="{loc:Loc MinDTPS}" Margin="0 20" FontSize="14" Foreground="White"/>
                            <Icon:PackIconMaterial Margin="20 0" Foreground="White" Width="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Icon:PackIconMaterial.Style>
                                    <Style TargetType="Icon:PackIconMaterial">
                                        <Setter Property="Kind" Value="Pen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinVPS}" Value="True">
                                                <Setter Property="Kind" Value="GamepadDown"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Icon:PackIconMaterial.Style>
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinVPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <StackPanel Cursor="Hand" ToolTip="{loc:Loc EditValue}" HorizontalAlignment="Center">
                            <TextBox Text="{Binding MinDTPS, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Bold" Foreground="Black" Width="125">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinVPS}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding ApplyMinVPSCommand}" Gesture="Enter" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="{Binding MinVPS}" FontSize="14" FontWeight="Bold" Foreground="White" Width="125">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinVPS}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinVPSCommand}" Gesture="LeftClick"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <DataGrid Grid.Row="1" CellStyle="{DynamicResource DataGridCellStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" AutoGenerateColumns="False"
                  RowStyle="{DynamicResource DataGridRowStyle1}" Style="{DynamicResource DataGridStyle1}" Margin="20" ItemsSource="{Binding Players}" SelectedItem="{Binding SelectedPlayer}"
                  Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:0:='}" Focusable="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn SortMemberPath="Username" IsReadOnly="True" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=Player.Username}" VerticalAlignment="Center" TextAlignment="Center" Margin="10" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Player}" TextAlignment="Center" FontSize="14" Foreground="White" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn IsReadOnly="True" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Path=DamageTakenPercentages}" HorizontalAlignment="Center" FontSize="12" />
                                <TextBlock Text="%" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageTaken" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ProgressBar Height="20" Width="400" Margin="20 0" Value="{Binding Path=DamageTaken}" Maximum="{Binding DataContext.BestValue, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <TextBlock Text="{Binding Path=DamageTaken, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc DamageTaken}" TextAlignment="Center" FontSize="14" Foreground="White" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageTakenPerSecond" IsReadOnly="True" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=DamageTakenPerSecond, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc DTPS}" TextAlignment="Center" FontSize="14" Foreground="White" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="AverageItemLevel" IsReadOnly="True" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=AverageItemLevel, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc AverageItemLevel}" TextAlignment="Center" FontSize="14" Foreground="White" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Margin="0 25" Orientation="Horizontal">
            <StackPanel Margin="140 0">
                <TextBlock Text="{loc:Loc TotalDamageTaken}" FontSize="13" TextAlignment="Center" Foreground="White" />
                <TextBlock Text="{Binding TotalValue, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 10" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Margin="140 0">
                <TextBlock Text="{loc:Loc TotalDTPS}" FontSize="13" TextAlignment="Center" Foreground="White" />
                <TextBlock Text="{Binding TotalVPS, StringFormat=0.00, Converter={StaticResource IntToEnhancedInt}}" Foreground="White" TextAlignment="Center" Margin="0 10" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Margin="140 0">
                <TextBlock Text="{loc:Loc AverageDamageTaken}" FontSize="13" TextAlignment="Center" Foreground="White" />
                <TextBlock Text="{Binding AverageValue, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 10" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Margin="140 0">
                <TextBlock Text="{loc:Loc AverageDTPS}" FontSize="13" TextAlignment="Center" Foreground="White" />
                <TextBlock Text="{Binding AverageVPS, StringFormat=0.00, Converter={StaticResource IntToEnhancedInt}}" Foreground="White" TextAlignment="Center" Margin="0 10" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</views:MvxWpfView>
