<views:MvxWpfView
    x:Class="CombatAnalysis.App.Views.CombatPlayersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:CombatAnalysis.App.Converters"
    xmlns:convertersCombat="clr-namespace:CombatAnalysis.App.Converters.CombatLogs"
    xmlns:loc="clr-namespace:CombatAnalysis.App.Localizations"
    xmlns:resx="clr-namespace:CombatAnalysis.App.Localizations.Resources.CombatPlayers"
    xmlns:local="clr-namespace:CombatAnalysis.App.Views.ViewTemplates"
    xmlns:basicViewModel="clr-namespace:CombatAnalysis.Core.ViewModels.ViewModelTemplates;assembly=CombatAnalysis.Core"
    xmlns:views="clr-namespace:MvvmCross.Platforms.Wpf.Views;assembly=MvvmCross.Platforms.Wpf"
    xmlns:uc="clr-namespace:CombatAnalysis.App.UserControls.ModalWindows"
    xmlns:mvx="clr-namespace:MvvmCross.Platforms.Wpf.Binding;assembly=MvvmCross.Platforms.Wpf"
    loc:LocalizationObject.ResourceManager="{x:Static resx:Resource.ResourceManager}"
    mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1250">

    <Grid>
        <Grid.Resources>
            <converters:TheNativeIntToVisibilityConverter x:Key="IntToVisibility" />
            <converters:TheNativeBoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
            <convertersCombat:IntToEnhancedIntConverter x:Key="IntToEnhancedInt" />
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="0.12*"/>
            <RowDefinition Height="0.19*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="0.15*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.ColumnSpan="4" Grid.RowSpan="5" Content="{Binding Basic}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type basicViewModel:BasicTemplateViewModel}">
                    <local:BasicTemplateView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!--#region Combat data -->
        
        <Grid Visibility="Hidden">
            <ProgressBar Name="maxDamageDone" Value="{Binding Combat.DamageDone}" Maximum="{Binding Combat.DamageDone}" />
            <ProgressBar Name="maxHealDone" Value="{Binding Combat.HealDone}" Maximum="{Binding Combat.HealDone}" />
            <ProgressBar Name="maxEnergyRecovery" Value="{Binding Combat.EnergyRecovery}" Maximum="{Binding Combat.EnergyRecovery}" />
        </Grid>
        
        <!--#endregion-->
        
        <StackPanel Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal" ToolTip="{loc:Loc CombatName}">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{loc:Loc Title}" Foreground="White"
                       Margin="50 0" Style="{StaticResource titleText}"/>
            <StackPanel Orientation="Horizontal">
                <Icon:PackIconMaterial Kind="Skull" Width="13" HorizontalAlignment="Center" Margin="10 0" VerticalAlignment="Center" Foreground="Red"/>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Combat.Name}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Icon:PackIconMaterial Kind="Check" Foreground="Green" Style="{StaticResource menuButtonIcon}"
                                       ToolTip="{loc:Loc Win}"
                                       Visibility="{Binding Combat.IsWin, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}"/>
                <Icon:PackIconMaterial Kind="SwordCross" Foreground="Red" Style="{StaticResource menuButtonIcon}"
                                       ToolTip="{loc:Loc Lose}"
                                       Visibility="{Binding Combat.IsWin, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Top" Orientation="Horizontal">
            <StackPanel>
                <TextBlock Text="{loc:Loc TotalValue}" FontSize="16" Foreground="White"/>
            </StackPanel>
            <Icon:PackIconMaterial Kind="ToggleSwitchOff" Width="125" Height="18" Cursor="Hand" Foreground="White"
                                    VerticalAlignment="Bottom" Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:0:='}">
                <Icon:PackIconMaterial.InputBindings>
                    <MouseBinding Command="{Binding SwitchBetweenValuesCommand}" CommandParameter="1" Gesture="LeftClick" />
                </Icon:PackIconMaterial.InputBindings>
            </Icon:PackIconMaterial>
            <Icon:PackIconMaterial Kind="ToggleSwitch" Width="125" Height="18" Cursor="Hand"
                                    VerticalAlignment="Bottom" Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:1:='}">
                <Icon:PackIconMaterial.InputBindings>
                    <MouseBinding Command="{Binding SwitchBetweenValuesCommand}" CommandParameter="0" Gesture="LeftClick"/>
                </Icon:PackIconMaterial.InputBindings>
                <Icon:PackIconMaterial.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#462ADB" Offset="0"/>
                        <GradientStop Color="#DA34AE" Offset="0.75"/>
                        <GradientStop Color="#8A16C1" Offset="1"/>
                    </LinearGradientBrush>
                </Icon:PackIconMaterial.Foreground>
            </Icon:PackIconMaterial>
            <StackPanel>
                <TextBlock Text="{loc:Loc ValuePerSecond}" FontSize="16" Foreground="White"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20 10">
            <TextBlock Text="{Binding SelectedPlayer.Username}" Foreground="White" FontSize="16" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20 0">
            <TextBlock Text="{loc:Loc Filters}" FontSize="16" Margin="0 5" Foreground="White" />
            <StackPanel Orientation="Horizontal">
                <ComboBox Style="{DynamicResource ComboBoxStyle1}" Width="175" ItemsSource="{Binding FilterList}" SelectedIndex="{Binding SeletedFilterIndex}" />
                <Icon:PackIconMaterial Kind="TrashCan" Cursor="Hand" Foreground="Orange" Width="10" Margin="15 5" HorizontalAlignment="Center"
                                       VerticalAlignment="Top" ToolTip="{loc:Loc ClearFilters}">
                    <Icon:PackIconMaterial.InputBindings>
                        <MouseBinding Command="{Binding FilterClearCommand}" Gesture="LeftClick"/>
                    </Icon:PackIconMaterial.InputBindings>
                </Icon:PackIconMaterial>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Margin="0 -5"
                    HorizontalAlignment="Center" Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:0:='}"> 
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="250"
                            Visibility="{Binding UseFilterByMinDamageDone, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="0 10" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinDamageDoneCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <StackPanel Orientation="Horizontal" Margin="0 5">
                            <TextBlock Text="{loc:Loc MinDamage}" Margin="0 5" FontSize="14" Foreground="White"/>
                            <Icon:PackIconMaterial Margin="15 5" Foreground="White" Width="13" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.Style>
                                    <Style TargetType="Icon:PackIconMaterial">
                                        <Setter Property="Kind" Value="Pen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinDamageDone}" Value="True">
                                                <Setter Property="Kind" Value="GamepadDown"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Icon:PackIconMaterial.Style>
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinDamageDoneCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <Grid Cursor="Hand" ToolTip="{loc:Loc EditValue}" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Text="{Binding MinDamageDone, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Bold" Foreground="Black" Width="125">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinDamageDone}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding ApplyMinDamageDoneCommand}" Gesture="Enter" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Grid.Row="1" Text="{Binding MinDamageDone}" FontSize="14" FontWeight="Bold" Foreground="White" Width="125">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinDamageDone}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinDamageDoneCommand}" Gesture="LeftClick"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"
                            Visibility="{Binding UseFilterByMinHealDone, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="0 10" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinHealDoneCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <StackPanel Orientation="Horizontal" Margin="0 5">
                            <TextBlock Text="{loc:Loc MinHeal}" Margin="0 5" FontSize="14" Foreground="White"/>
                            <Icon:PackIconMaterial Margin="15 5" Foreground="White" Width="13" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.Style>
                                    <Style TargetType="Icon:PackIconMaterial">
                                        <Setter Property="Kind" Value="Pen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinHealDone}" Value="True">
                                                <Setter Property="Kind" Value="GamepadDown"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Icon:PackIconMaterial.Style>
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinHealDoneCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <Grid Cursor="Hand" ToolTip="{loc:Loc EditValue}" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Text="{Binding MinHealDone, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Bold" Foreground="Black" Width="125">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinHealDone}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding ApplyMinHealDoneCommand}" Gesture="Enter" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Grid.Row="1" Text="{Binding MinHealDone}" FontSize="14" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinHealDone}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinHealDoneCommand}" Gesture="LeftClick"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"
                            Visibility="{Binding UseFilterByMinEnergyRecovery, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="0 10" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinEnergyRecoveryCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <StackPanel Orientation="Horizontal" Margin="0 5">
                            <TextBlock Text="{loc:Loc MinResources}" Margin="0 5" FontSize="14" Foreground="White"/>
                            <Icon:PackIconMaterial Margin="15 5" Foreground="White" Width="13" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.Style>
                                    <Style TargetType="Icon:PackIconMaterial">
                                        <Setter Property="Kind" Value="Pen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinEnergyRecovery}" Value="True">
                                                <Setter Property="Kind" Value="GamepadDown"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Icon:PackIconMaterial.Style>
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinEnergyRecoveryCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <Grid Cursor="Hand" ToolTip="{loc:Loc EditValue}" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="20"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0" Text="{Binding MinEnergyRecovery, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Bold" Foreground="Black" Width="125">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinEnergyRecovery}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding ApplyMinEnergyRecoveryCommand}" Gesture="Enter" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Grid.Row="1" Text="{Binding MinEnergyRecovery}" FontSize="14" Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OpenEditMinEnergyRecovery}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinEnergyRecoveryCommand}" Gesture="LeftClick"/>
                                </TextBlock.InputBindings>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2" Margin="0"
                    HorizontalAlignment="Center" Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:1:='}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"
                            Visibility="{Binding UseFilterByMinDPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="-20 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinDPSCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <TextBlock Text="{loc:Loc MinDPS}" Margin="0 5" FontSize="12" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinDPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}">
                            <TextBlock Text="{Binding MinDPS}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="Pen" Foreground="White" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinDPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinDPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                            <TextBox Text="{Binding MinDPS, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="GamepadDown" Foreground="Green" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinDPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"
                            Visibility="{Binding UseFilterByMinHPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="-20 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinHPSCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <TextBlock Text="{loc:Loc MinHPS}" Margin="0 5" FontSize="12" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinHPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}">
                            <TextBlock Text="{Binding MinHPS}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="Pen" Foreground="White" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinHPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinHPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                            <TextBox Text="{Binding MinHPS, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="GamepadDown" Foreground="Green" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinHPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"
                            Visibility="{Binding UseFilterByMinRPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <Icon:PackIconMaterial Kind="Close" Cursor="Hand" Foreground="Red" Width="10" Margin="-20 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding UseFilterByMinRPSCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                    <StackPanel Margin="20 0">
                        <TextBlock Text="{loc:Loc MinRPS}" Margin="0 5" FontSize="12" Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinRPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}">
                            <TextBlock Text="{Binding MinRPS}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="Pen" Foreground="White" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding OpenEditMinRPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Cursor="Hand" ToolTip="{loc:Loc EditValue}"
                                    Visibility="{Binding OpenEditMinRPS, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                            <TextBox Text="{Binding MinRPS, UpdateSourceTrigger=PropertyChanged}" Width="90" Margin="0 5" FontSize="12" FontWeight="Bold" Foreground="White"/>
                            <Icon:PackIconMaterial Kind="GamepadDown" Foreground="Green" Width="13" Margin="10 6" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Icon:PackIconMaterial.InputBindings>
                                    <MouseBinding Command="{Binding ApplyMinRPSCommand}" Gesture="LeftClick"/>
                                </Icon:PackIconMaterial.InputBindings>
                            </Icon:PackIconMaterial>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dataGrid1" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
                  CellStyle="{DynamicResource DataGridCellStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" AutoGenerateColumns="False"
                  RowStyle="{DynamicResource DataGridRowStyle1}" Style="{DynamicResource DataGridStyle1}" Height="550" Width="auto"
                  Margin="20" ItemsSource="{Binding PlayersCombat}" SelectedItem="{Binding SelectedPlayer}"
                  Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:0:='}" Focusable="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn SortMemberPath="Username" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=Username}" VerticalAlignment="Center" TextAlignment="Center" Margin="10" FontSize="12" />
                                <Button Command="{Binding DataContext.OpenStatsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Content="Stats" Width="75" FontSize="16"
                                        Style="{StaticResource violentButton}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Player}" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageDone" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=DamageDone, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Damage}" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="HealDone" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=HealDone, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Healing}" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageTaken" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=DamageTaken, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc DamageTaken}" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="ResourcesRecovery" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=ResourcesRecovery, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Resources}" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn IsReadOnly="True" x:Name="damageEfficiency">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding PlayerParseInfo.DamageEfficiency}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Damage, %" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn IsReadOnly="True" x:Name="healEfficiency">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding PlayerParseInfo.HealEfficiency}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Heal, %" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="AverageItemLevel" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=AverageItemLevel, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc AverageItemLevel}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" 
                  CellStyle="{DynamicResource DataGridCellStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" 
                  RowStyle="{DynamicResource DataGridRowStyle1}" Style="{DynamicResource DataGridStyle1}" Height="550"
                  Margin="20" ItemsSource="{Binding PlayersCombat}" SelectedItem="{Binding SelectedPlayer}"
                  Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:1:='}">
            <DataGrid.Columns>
                <DataGridTemplateColumn SortMemberPath="Username" IsReadOnly="True" Width="175">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=Username}" VerticalAlignment="Center" TextAlignment="Center" Margin="10" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Player}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageDone" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=DamageDonePerSecond, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc DamagePerSecond}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="HealDone" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=HealDonePerSecond, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc HealingPerSecond}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="EnergyRecovery" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=ResourcesRecoveryPerSecond, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc ResourcesPerSecond}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="AverageItemLevel" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=AverageItemLevel, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc AverageItemLevel}" Margin="5" TextAlignment="Center" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top">
            <CheckBox Style="{DynamicResource CheckBoxStyle1}" VerticalContentAlignment="Center" 
                  Content="{loc:Loc ShowSummaryInform}" Width="200" Margin="40 10" IsChecked="{Binding ShowSummaryInformation}" />
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="0 15"
                    Visibility="{Binding ShowSummaryInformation, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:0:='}">
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc AverageDamage}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageDamage, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="90 0">
                    <TextBlock Text="{loc:Loc AverageHeal}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageHeal, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc AverageResources}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageResources, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:1:='}">
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc AverageDamagePerSecond}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageDamagePerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="90 0">
                    <TextBlock Text="{loc:Loc AverageHealPerSecond}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageHealPerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc AverageResourcesPerSecond}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding AverageResourcesPerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="0 15"
                    Visibility="{Binding ShowSummaryInformation, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:0:='}">
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc TotalDamage}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding TotalDamage, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="90 0">
                    <TextBlock Text="{loc:Loc TotalHeal}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding TotalHeal, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc TotalResoures}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding TotalResoures, Converter={StaticResource IntToEnhancedInt}}" TextAlignment="Center" Foreground="White" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='true:1:='}">
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc TotalDamagePerSecond}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding TotalDamagePerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="90 0">
                    <TextBlock Text="{loc:Loc TotalHealPerSecond}" FontSize="13" Foreground="White" />
                    <TextBlock Text="{Binding TotalHealPerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Margin="140 0">
                    <TextBlock Text="{loc:Loc TotalResourcesPerSecond}" FontSize="13" Foreground="White"/>
                    <TextBlock Text="{Binding TotalResourcesPerSecond, StringFormat=0.00}" Foreground="White" TextAlignment="Center" Margin="0 5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <uc:PlayerStats Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2"
            IsOpen="{Binding IsModalOpen}" 
            ModalWidth="{Binding ModalWidth}" 
            ModalHeight="{Binding ModalHeight}" 
            Title="{Binding ModalTitle}" 
            ModalBackground="White" 
            OverlayBackground="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="0.5*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Margin" Value="0 5"/>
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                    </Style>
                </Grid.Resources>
                
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="{Binding SelectedPlayer.Username}" FontSize="14" />
                </StackPanel>
                
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="Attributes" FontSize="16" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Strength: " FontSize="14" />
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Strength}" FontSize="14" Opacity="0.5"/>
                        <Icon:PackIconMaterial Kind="Star" Cursor="Hand" Foreground="Green" Margin="10 0">
                            <Icon:PackIconMaterial.Style>
                                <Style TargetType="Icon:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerMainStat}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Icon:PackIconMaterial.Style>
                        </Icon:PackIconMaterial>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Agility: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Agility}" FontSize="14" Opacity="0.5"/>
                        <Icon:PackIconMaterial Kind="Star" Cursor="Hand" Foreground="Green" Margin="10 0">
                            <Icon:PackIconMaterial.Style>
                                <Style TargetType="Icon:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerMainStat}" Value="1">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Icon:PackIconMaterial.Style>
                        </Icon:PackIconMaterial>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Intelligence: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Intelligence}" FontSize="14" Opacity="0.5"/>
                        <Icon:PackIconMaterial Kind="Star" Cursor="Hand" Foreground="Green" Margin="10 0">
                            <Icon:PackIconMaterial.Style>
                                <Style TargetType="Icon:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerMainStat}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Icon:PackIconMaterial.Style>
                        </Icon:PackIconMaterial>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Stamina: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Stamina}" FontSize="14" Opacity="0.5"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Crit: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Crit}" FontSize="14" Opacity="0.5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Haste: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Haste}" FontSize="14" Opacity="0.5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Hit: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Hit}" FontSize="14" Opacity="0.5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Armor: " FontSize="14"/>
                        <TextBlock Text="{Binding SelectedPlayer.Stats.Armor}" FontSize="14" Opacity="0.5"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="Talents" FontSize="16" />
                </StackPanel>
                
                <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Text="{Binding SelectedPlayer.Stats.Talents}" FontSize="14"/>
                </StackPanel>
                
                <Button Grid.Row="6" Grid.ColumnSpan="2" Command="{Binding OpenStatsCommand}"
                                    Content="Close" Width="100" Height="40" FontSize="14"
                                    Style="{StaticResource showButton}"/>
            </Grid>

        </uc:PlayerStats>
    </Grid>
</views:MvxWpfView>
