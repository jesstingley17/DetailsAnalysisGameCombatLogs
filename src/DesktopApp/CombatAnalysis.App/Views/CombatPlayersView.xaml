<views:MvxWpfView
    x:Class="CombatAnalysis.App.Views.CombatPlayersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:CombatAnalysis.App.Converters"
    xmlns:loc="clr-namespace:CombatAnalysis.App.Localizations"
    xmlns:resx="clr-namespace:CombatAnalysis.App.Localizations.Resources.CombatPlayers"
    xmlns:local="clr-namespace:CombatAnalysis.App.Views.ViewTemplates"
    xmlns:basicViewModel="clr-namespace:CombatAnalysis.Core.ViewModels.ViewModelTemplates;assembly=CombatAnalysis.Core"
    xmlns:views="clr-namespace:MvvmCross.Platforms.Wpf.Views;assembly=MvvmCross.Platforms.Wpf"
    xmlns:mvx="clr-namespace:MvvmCross.Platforms.Wpf.Binding;assembly=MvvmCross.Platforms.Wpf"
    xmlns:combatPlayersViews="clr-namespace:CombatAnalysis.App.Views.CombatPlayers"
    loc:LocalizationObject.ResourceManager="{x:Static resx:Resource.ResourceManager}"
    mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1250">

    <Grid>
        <Grid.Resources>
            <converters:TheNativeBoolToVisibilityConverter x:Key="BoolToVisibility" />
        </Grid.Resources>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="0.15*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.ColumnSpan="4" Grid.RowSpan="5" Content="{Binding Basic}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type basicViewModel:BasicTemplateViewModel}">
                    <local:BasicTemplateView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <StackPanel Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Orientation="Horizontal" ToolTip="{loc:Loc CombatName}">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{loc:Loc Title}" Foreground="White"
                       Margin="50 0" Style="{StaticResource titleText}"/>
            <StackPanel Orientation="Horizontal">
                <Icon:PackIconMaterial Kind="Skull" Width="13" HorizontalAlignment="Center" Margin="10 0" VerticalAlignment="Center" Foreground="Red"/>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Combat.Boss.Name}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <Icon:PackIconMaterial Kind="Check" Foreground="Green" Style="{StaticResource menuButtonIcon}"
                                       ToolTip="{loc:Loc Win}"
                                       Visibility="{Binding Combat.IsWin, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}"/>
                <Icon:PackIconMaterial Kind="SwordCross" Foreground="Red" Style="{StaticResource menuButtonIcon}"
                                       ToolTip="{loc:Loc Lose}"
                                       Visibility="{Binding Combat.IsWin, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}"/>
            </StackPanel>
        </StackPanel>

        <TabControl Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" Margin="25"
                    SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="{loc:Loc Info}" Style="{StaticResource TabItemStyle1}">
                <combatPlayersViews:PlayerInfoView DataContext="{Binding PlayerInfoVM}" />
            </TabItem>
            <TabItem Header="{loc:Loc DamageDone}" Style="{StaticResource TabItemStyle1}">
                <combatPlayersViews:DamageDoneScoreView DataContext="{Binding DamageDoneScoreVM}" />
            </TabItem>
            <TabItem Header="{loc:Loc HealDone}" Style="{StaticResource TabItemStyle1}">
                <combatPlayersViews:HealDoneScoreView DataContext="{Binding HealDoneScoreVM}" />
            </TabItem>
            <TabItem Header="{loc:Loc DamageTaken}" Style="{StaticResource TabItemStyle1}">
                <combatPlayersViews:DamageTakenScoreView DataContext="{Binding DamageTakenScoreVM}" />
            </TabItem>
            <TabItem Header="{loc:Loc ResourcesRecovery}" Style="{StaticResource TabItemStyle1}">
                <combatPlayersViews:ResourcesRecoveryScoreView DataContext="{Binding ResourcesRecoveryScoreVM}" />
            </TabItem>
        </TabControl>
    </Grid>
</views:MvxWpfView>
