<views:MvxWpfView x:Class="CombatAnalysis.App.Views.CombatLogs.ParsingCombatLogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:CombatAnalysis.App.Converters"
    xmlns:loc="clr-namespace:CombatAnalysis.App.Localizations"
    xmlns:resx="clr-namespace:CombatAnalysis.App.Localizations.Resources.CombatLogs"
    xmlns:local="clr-namespace:CombatAnalysis.App.Views.ViewTemplates"
    xmlns:basicViewModel="clr-namespace:CombatAnalysis.Core.ViewModels.ViewModelTemplates;assembly=CombatAnalysis.Core"
    xmlns:mvx="clr-namespace:MvvmCross.Platforms.Wpf.Binding;assembly=MvvmCross.Platforms.Wpf"
    xmlns:views="clr-namespace:MvvmCross.Platforms.Wpf.Views;assembly=MvvmCross.Platforms.Wpf"
    loc:LocalizationObject.ResourceManager="{x:Static resx:Resource.ResourceManager}"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <converters:TheNativeStringToVisibilityConverter x:Key="ToVisibility" />
            <converters:TheNativeStringToXAMLBoolConverter x:Key="ToXAMLBool" />
            <converters:TheNativeBoolToXAMLBoolConverter x:Key="BoolToXAMLBool" />
            <converters:TheNativeBoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:TheNativeIntToVisibilityConverter x:Key="IntToVisibility" />
            <converters:TheNativeIntToXAMLBoolConverter x:Key="IntToXAMLBool" />
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="0.7*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="4" Grid.Row="0" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" IsEnabled="{Binding IsParsing, Converter={StaticResource BoolToXAMLBool}, ConverterParameter=true}"
                    HorizontalAlignment="Center" VerticalAlignment="Top" MinWidth="375">
                <TextBlock HorizontalAlignment="Center" Text="{loc:Loc UploadFile}" Margin="0 20" FontSize="16" Foreground="White" />
                <Button Click="SelectCmbatLogFiles" Content="{loc:Loc SelectFile}" Width="125" FontSize="16"
                        Margin="15 0" Style="{StaticResource showButton}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CombatLogNames.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ListBox Style="{DynamicResource ListBoxStyle1}" ItemsSource="{Binding CombatLogNames}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontWeight="Bold" Margin="0 5" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                            Visibility="{Binding ShowConnectMore, Converter={StaticResource BoolToVisibility}}">
                    <Button Click="SelectMoreCmbatLogFiles" Style="{StaticResource showButton}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Plus" Foreground="Green" Style="{StaticResource menuButtonIcon}"
                                           ToolTip="{loc:Loc RemovePrivateLog}" Height="15" Margin="5 0" />
                                <TextBlock Text="Connect more" FontSize="12" Foreground="White" Margin="10 0" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Row="1" IsEnabled="{Binding IsAuth, Converter={StaticResource BoolToXAMLBool}}" MaxWidth="500" HorizontalAlignment="Center">
                <TextBlock Text="{loc:Loc TypeOfLogs}" Margin="0 10" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Margin="20">
                    <RadioButton Style="{DynamicResource RadioButtonStyle1}" Content="{loc:Loc Public}" Width="140" mvx:Bi.nd="Command GetLogTypeCommand, CommandParameter=0"
                                 IsChecked="{Binding LogType, Converter={StaticResource IntToXAMLBool}, ConverterParameter=0}" Margin="20" />
                    <RadioButton Style="{DynamicResource RadioButtonStyle1}" Content="{loc:Loc Private}" Width="140" mvx:Bi.nd="Command GetLogTypeCommand, CommandParameter=1"
                                 IsChecked="{Binding LogType, Converter={StaticResource IntToXAMLBool}, ConverterParameter=1}" Margin="20" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0 50" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" IsEnabled="{Binding CombatLogNames.Count, Converter={StaticResource IntToXAMLBool}, ConverterParameter=0:>}">
                <Button Name="combatLogFileAnalysis" Width="150" Margin="0 20" Content="{loc:Loc Processing}" FontSize="16"
                        mvx:Bi.nd="Command OpenPlayerAnalysisCommand" Style="{StaticResource showButton}" />
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsEnabled="{Binding IsAllowSaveLogs, Converter={StaticResource BoolToXAMLBool}, ConverterParameter=false}">
                    <CheckBox Style="{DynamicResource CheckBoxStyle1}" Name="isSaveCombatLog" Width="150"
                              VerticalAlignment="Center" VerticalContentAlignment="Center"
                              Content="{loc:Loc SaveData}" IsChecked="{Binding IsNeedSave}" FontSize="14"
                              IsEnabled="{Binding IsAuth, Converter={StaticResource BoolToXAMLBool}, ConverterParameter=false}" />
                    <TextBlock Text="{loc:Loc ToSaveYouShouldBeLogin}" TextAlignment="Center" Opacity="0.5" Foreground="White" Margin="0 5"
                            Visibility="{Binding IsAuth, Converter={StaticResource BoolToVisibility}, ConverterParameter=false:true}"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Row="1" Margin="0 10" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal"
                        Visibility="{Binding IsParsing, Converter={StaticResource BoolToVisibility}, ConverterParameter=true}">
                <TextBlock Width="175" Text="{loc:Loc Processing}" FontSize="16" TextAlignment="Center" Foreground="White">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource FadeLoadingStoryboard}" />
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <Icon:PackIconMaterial Kind="WindowClose" Foreground="Red" HorizontalAlignment="Right" Cursor="Hand" Background="Transparent" Margin="0 5" ToolTip="{loc:Loc Cancel}">
                    <Icon:PackIconMaterial.InputBindings>
                        <MouseBinding Command="{Binding CancelParsingCommand}" Gesture="LeftClick"/>
                    </Icon:PackIconMaterial.InputBindings>
                </Icon:PackIconMaterial>
            </StackPanel>
            
            <StackPanel Grid.Row="2" Margin="0 10">
                <TextBlock TextWrapping="Wrap" Text="{loc:Loc ProcessingFailed}"
                       Visibility="{Binding FileIsCorrect, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:true}"
                       FontSize="16" TextAlignment="Center" Foreground="Orange" />
                <StackPanel Margin="0 10" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="{Binding CombatLogUploadingFailed, Converter={StaticResource BoolToVisibility}, ConverterParameter=true:false}">
                    <TextBlock Text="{loc:Loc CombatLogUploadingFailed}" FontSize="14" TextWrapping="Wrap"
                       MaxWidth="650" Foreground="Red" Margin="20 0" />
                    <Icon:PackIconMaterial Kind="Reload" Foreground="White" Cursor="Hand" Width="20" Height="20" Background="Transparent" ToolTip="{loc:Loc Repeat}">
                        <Icon:PackIconMaterial.InputBindings>
                            <MouseBinding Command="{Binding OpenPlayerAnalysisCommand}" Gesture="LeftClick"/>
                        </Icon:PackIconMaterial.InputBindings>
                    </Icon:PackIconMaterial>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</views:MvxWpfView>
