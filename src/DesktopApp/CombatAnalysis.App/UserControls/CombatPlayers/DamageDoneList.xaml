<UserControl x:Class="CombatAnalysis.App.UserControls.CombatPlayers.DamageDoneList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:convertersCombat="clr-namespace:CombatAnalysis.App.Converters.CombatLogs"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:CombatAnalysis.App.Converters"
             xmlns:resx="clr-namespace:CombatAnalysis.App.Localizations.Resources.CombatPlayers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:loc="clr-namespace:CombatAnalysis.App.Localizations"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CombatAnalysis.App.UserControls.CombatPlayers"
             loc:LocalizationObject.ResourceManager="{x:Static resx:Resource.ResourceManager}">
    <StackPanel>
        <StackPanel.Resources>
            <converters:TheNativeIntToVisibilityConverter x:Key="IntToVisibility" />
            <converters:TheNativeBoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
            <convertersCombat:IntToEnhancedIntConverter x:Key="IntToEnhancedInt" />
        </StackPanel.Resources>

        <DataGrid x:Name="dataGrid1" CellStyle="{DynamicResource DataGridCellStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" AutoGenerateColumns="False"
                  RowStyle="{DynamicResource DataGridRowStyle1}" Style="{DynamicResource DataGridStyle1}" Height="550" Width="auto" Margin="20" ItemsSource="{Binding Players}" SelectedItem="{Binding SelectedPlayer}"
                  Visibility="{Binding CombatInformationType, Converter={StaticResource IntToVisibility}, ConverterParameter='false:0:='}" Focusable="False">
            <DataGrid.Columns>
                <DataGridTemplateColumn SortMemberPath="Username" IsReadOnly="True" Width="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=Username}" VerticalAlignment="Center" TextAlignment="Center" Margin="10" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Player}" TextAlignment="Center" FontSize="12" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn IsReadOnly="True" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Path=DamageDonePercentages}" HorizontalAlignment="Center" FontSize="12" />
                                <TextBlock Text="%" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="%" Margin="5" TextAlignment="Center" FontSize="12" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn SortMemberPath="DamageDone" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ProgressBar Height="20" Width="400" Margin="20 0" Value="{Binding Path=DamageDone}" Maximum="{Binding DataContext.BestDamageDone, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <TextBlock Text="{Binding Path=DamageDone, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc Damage}" TextAlignment="Center" FontSize="12" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn SortMemberPath="DamageDonePerSecond" IsReadOnly="True" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Path=DamageDonePerSecond, Converter={StaticResource IntToEnhancedInt}}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc DPS}" TextAlignment="Center" FontSize="12" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn SortMemberPath="AverageItemLevel" IsReadOnly="True" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock Text="{Binding Path=AverageItemLevel, StringFormat=0.00}" HorizontalAlignment="Center" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{loc:Loc AverageItemLevel}" Margin="5" TextAlignment="Center" FontSize="12" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>
